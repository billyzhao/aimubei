// 永念 EverMind - Prisma Schema
// 本地开发用 SQLite，生产环境切换 PostgreSQL 只需改 provider

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ====================================
// 用户系统
// ====================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  avatar        String?
  role          String    @default("USER") // USER | ADMIN
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 关联
  memorials     Memorial[]
  tributes      Tribute[]
  chatMessages  ChatMessage[]
  accounts      Account[]
  sessions      Session[]
}

// NextAuth 所需表
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ====================================
// 纪念馆核心模型
// ====================================

model Memorial {
  id            String          @id @default(cuid())
  slug          String          @unique
  name          String
  title         String
  bio           String
  personality   String?
  traits        String          @default("[]") // JSON array
  quotes        String          @default("[]") // JSON array
  birthYear     Int
  deathYear     Int
  avatar        String?
  coverImage    String?
  isPublic      Boolean         @default(true)
  isVerified    Boolean         @default(false)
  visitorCount  Int             @default(0)
  tributeCount  Int             @default(0)
  ownerId       String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // 关联
  owner         User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  timeline      TimelineEvent[]
  tributes      Tribute[]
  photos        Photo[]
  chatMessages  ChatMessage[]
}

model TimelineEvent {
  id          String   @id @default(cuid())
  memorialId  String
  year        Int
  title       String
  description String
  icon        String   @default("🌿")
  order       Int      @default(0)

  memorial Memorial @relation(fields: [memorialId], references: [id], onDelete: Cascade)

  @@index([memorialId])
}

model Photo {
  id          String   @id @default(cuid())
  memorialId  String
  url         String
  caption     String?
  order       Int      @default(0)

  memorial Memorial @relation(fields: [memorialId], references: [id], onDelete: Cascade)

  @@index([memorialId])
}

model Tribute {
  id            String   @id @default(cuid())
  memorialId    String
  type          String   // flower | candle | message
  visitorName   String
  visitorId     String?
  content       String?
  createdAt     DateTime @default(now())

  memorial Memorial @relation(fields: [memorialId], references: [id], onDelete: Cascade)
  visitor  User?    @relation(fields: [visitorId], references: [id], onDelete: SetNull)

  @@index([memorialId])
}

model ChatMessage {
  id          String   @id @default(cuid())
  memorialId  String
  userId      String?
  role        String   // user | assistant
  content     String
  createdAt   DateTime @default(now())

  memorial Memorial @relation(fields: [memorialId], references: [id], onDelete: Cascade)
  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([memorialId])
}
