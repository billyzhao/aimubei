// 永念 EverMind - Prisma Schema
// 本地开发用 SQLite，生产环境切换 PostgreSQL 只需改 provider

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ====================================
// 用户系统
// ====================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  avatar        String?
  role          String    @default("USER") // USER | ADMIN
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 关联
  memorials     Memorial[]
  tributes      Tribute[]
  chatMessages  ChatMessage[]
  accounts      Account[]
  sessions      Session[]
  inviteCodes   InviteCode[] @relation("InviteCreator")
  usedInvites   InviteCode[] @relation("InviteUser")
}

// NextAuth 所需表
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ====================================
// 纪念馆核心模型
// ====================================

model Memorial {
  id            String          @id @default(cuid())
  slug          String          @unique
  name          String
  title         String
  bio           String
  personality   String?
  traits        String          @default("[]") // JSON array
  quotes        String          @default("[]") // JSON array
  birthYear     Int
  deathYear     Int
  avatar        String?
  coverImage    String?
  // 权限：PUBLIC(公开) | FAMILY(亲友) | PRIVATE(私密)
  visibility    String          @default("PUBLIC")
  isPublic      Boolean         @default(true) // 旧字段保留兼容，与visibility同步
  // 私密纪念馆访问密码（bcrypt 哈希），仅 PRIVATE 且设置后生效
  accessPassword String?
  isVerified    Boolean         @default(false)
  visitorCount  Int             @default(0)
  tributeCount  Int             @default(0)
  ownerId       String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // 关联
  owner         User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  timeline      TimelineEvent[]
  tributes      Tribute[]
  photos        Photo[]
  chatMessages  ChatMessage[]
  inviteCodes   InviteCode[]
  letters       TimeLetter[]
  summaries     ConversationSummary[]
  keyMemories   KeyMemory[]
}

model TimelineEvent {
  id          String   @id @default(cuid())
  memorialId  String
  year        Int
  title       String
  description String
  icon        String   @default("🌿")
  order       Int      @default(0)

  memorial Memorial @relation(fields: [memorialId], references: [id], onDelete: Cascade)

  @@index([memorialId])
}

model Photo {
  id          String   @id @default(cuid())
  memorialId  String
  url         String
  caption     String?
  order       Int      @default(0)

  memorial Memorial @relation(fields: [memorialId], references: [id], onDelete: Cascade)

  @@index([memorialId])
}

model Tribute {
  id            String   @id @default(cuid())
  memorialId    String
  type          String   // flower | candle | message
  visitorName   String
  visitorId     String?
  content       String?
  createdAt     DateTime @default(now())

  memorial Memorial @relation(fields: [memorialId], references: [id], onDelete: Cascade)
  visitor  User?    @relation(fields: [visitorId], references: [id], onDelete: SetNull)

  @@index([memorialId])
}

model ChatMessage {
  id          String   @id @default(cuid())
  memorialId  String
  userId      String?
  role        String   // user | assistant
  content     String
  createdAt   DateTime @default(now())

  memorial Memorial @relation(fields: [memorialId], references: [id], onDelete: Cascade)
  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([memorialId])
}

// ====================================
// AI 记忆系统
// ====================================

// 对话摘要（每 10 轮自动生成）
model ConversationSummary {
  id          String   @id @default(cuid())
  memorialId  String
  content     String   // 摘要内容
  messageRange String  // "msg_1~msg_20" 标记覆盖范围
  createdAt   DateTime @default(now())

  memorial Memorial @relation(fields: [memorialId], references: [id], onDelete: Cascade)

  @@index([memorialId])
}

// 关键记忆（AI 提取的来访者信息）
model KeyMemory {
  id          String   @id @default(cuid())
  memorialId  String
  category    String   // visitor_name | occupation | relationship | emotion | other
  content     String   // "来访者叫小明" / "来访者是程序员" / "来访者是孙辈"
  createdAt   DateTime @default(now())

  memorial Memorial @relation(fields: [memorialId], references: [id], onDelete: Cascade)

  @@index([memorialId])
}

// ====================================
// 邀请码（亲友权限）
// ====================================

model InviteCode {
  id          String    @id @default(cuid())
  code        String    @unique
  memorialId  String
  createdById String
  usedById    String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  memorial   Memorial   @relation(fields: [memorialId], references: [id], onDelete: Cascade)
  createdBy  User       @relation("InviteCreator", fields: [createdById], references: [id], onDelete: Cascade)
  usedBy     User?      @relation("InviteUser", fields: [usedById], references: [id], onDelete: SetNull)

  @@index([memorialId])
}

// ====================================
// 时光信箱（定时信件 + AI回信）
// ====================================

model TimeLetter {
  id          String    @id @default(cuid())
  memorialId  String
  authorName  String
  authorId    String?
  content     String
  // PENDING(待送达) | DELIVERED(已送达) | REPLIED(已AI回信)
  status      String    @default("PENDING")
  deliverAt   DateTime
  aiReply     String?
  createdAt   DateTime  @default(now())

  memorial Memorial @relation(fields: [memorialId], references: [id], onDelete: Cascade)

  @@index([memorialId])
}
